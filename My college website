<!DOCTYPE html>
<html>
<head>
    <title>My College Website</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            font-family: Arial;
            margin: 0;
        }

        header {
            background: #2c3e50;
            color: white;
            text-align: center;
            padding: 15px;
        }

        nav {
            background: #34495e;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: yellow;
        }

        .container {
            padding: 20px;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
        }

        .column {
            flex: 33%;
            padding: 15px;
        }

        .box {
            background: #ecf0f1;
            padding: 20px;
            border-radius: 5px;
        }

        footer {
            background: #2c3e50;
            color: white;
            text-align: center;
            padding: 10px;
            margin-top: 20px;
        }

        /* Responsive Design */
        @media screen and (max-width: 768px) {
            .column {
                flex: 100%;
            }
        }
    </style>
</head>

<body>

<header>
    <h1>My College</h1>
    <p>Welcome to Our College Website</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Courses</a>
    <a href="#">Contact</a>
</nav>

<div class="container">
    <h2>About Our College</h2>
    <p>This is a simple responsive college website created using HTML and CSS.</p>

    <div class="row">
        <div class="column">
            <div class="box">
                <h3>Engineering</h3>
                <p>We provide quality engineering education.</p>
            </div>
        </div>

        <div class="column">
            <div class="box">
                <h3>Science</h3>
                <p>Explore various science programs.</p>
            </div>
        </div>

        <div class="column">
            <div class="box">
                <h3>Commerce</h3>
                <p>Best commerce courses available.</p>
            </div>
        </div>
    </div>
</div>

<footer>
    <p>© 2026 My College | All Rights Reserved</p>
</footer>

</body>
</html>
